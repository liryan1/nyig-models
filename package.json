{
  "name": "@nyig/models",
  "version": "0.7.0",
  "license": "MIT",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.mjs",
      "require": "./*.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/liryan1/nyig-models.git"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist node_modules",
    "format": "prettier --write src",
    "lint": "pnpm run format && tsc",
    "prepare": "husky",
    "prepublishOnly": "cp package.json README.md dist",
    "release": "pnpm run build && changeset publish"
  },
  "peerDependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "zod-to-ts": "^2.0.0"
  },
  "lint-staged": {
    "*.{js,ts,md}": "prettier --write"
  }
}